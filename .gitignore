# macOS
.DS_Store

# Xcode project — regenerated by xcodegen from project.yml
Forge.xcodeproj/

# Xcode build/user state
**/xcuserdata/
**/*.xcuserstate
DerivedData/

# Build outputs
build/
*.xcarchive
*.app
*.dmg

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved

# Notarization / signing — never commit these
*.p12
*.cer
*.pem
*.mobileprovision
ExportOptions-signed.plist

# Bundled OAuth credentials — copy Secrets.swift.example to set up locally
Forge/Sources/Modules/GoogleCalendar/Secrets.swift
