// Template for the gitignored Secrets.swift.
//
// Setup (one-time, per checkout):
//   cp Secrets.swift.example Forge/Sources/Modules/GoogleCalendar/Secrets.swift
//   # then fill in real values below
//
// The real file is gitignored so the bundled OAuth credentials never enter
// version control. They still ship in the binary (PKCE-protected desktop
// flow — see GoogleCalendarService.swift for the rationale).

enum Secrets {
    static let googleOAuthClientID = "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
    static let googleOAuthClientSecret = "YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
}
